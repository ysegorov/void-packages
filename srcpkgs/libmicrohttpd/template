# Template file for 'libmicrohttpd'
pkgname=libmicrohttpd
version=1.0.6
revision=1
build_style=gnu-configure
configure_args="
 --enable-https
 --enable-messages
 mhd_cv_works_func_epoll_create=yes
 mhd_cv_works_func_eventfd=yes"
hostmakedepends="pkg-config"
makedepends="gnutls-devel"
checkdepends="libcurl-devel"
short_desc="Library embedding HTTP server functionality"
maintainer="Duncaen <duncaen@voidlinux.org>"
license="LGPL-2.1-or-later"
homepage="https://www.gnu.org/software/libmicrohttpd/"
changelog="https://git.gnunet.org/gnunet/libmicrohttpd/file/ChangeLog.html"
distfiles="${GNU_SITE}/libmicrohttpd/libmicrohttpd-${version}.tar.gz"
checksum=bb5cfcadfc52dbd5eb512d6e2995e0361351c33e97a87aba426d3a4a7ba6cf70

libmicrohttpd-devel_package() {
	depends="${makedepends} ${sourcepkg}-${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/*.a
		vmove usr/lib/*.so
		vmove usr/share
	}
}
