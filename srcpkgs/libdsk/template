# Template file for 'libdsk'
pkgname=libdsk
version=1.5.22
revision=1
build_style=gnu-configure
make_install_args="install-man"
short_desc="Library and tools for accessing floppy discs and disc image files"
maintainer="0x5c <dev@0x5c.io>"
license="GPL-2.0-or-later"
homepage="https://www.seasip.info/Unix/LibDsk/"
distfiles="https://www.seasip.info/Unix/LibDsk/libdsk-${version}.tar.gz"
checksum=810f800bcc7665f4c1b35e19aaecb35f3729b712ad1d807105059b4bdb1cf049

post_install() {
	vsconf doc/libdskrc.sample
	for f in apridisk.html cfi.html libdsk.txt libdsk.pdf protocol.txt qrst.html; do
		vdoc "doc/$f"
	done
}

libdsk-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove "usr/share/doc/libdsk/libdsk.*"
	}
}
