# Template file for 'librime'
pkgname=librime
version=1.17.0
revision=1
build_style=cmake
configure_args="-DENABLE_LOGGING=OFF -DBUILD_TEST=ON"
hostmakedepends="pkg-config capnproto"
makedepends="boost-devel-minimal leveldb-devel marisa-devel opencc-devel
 yaml-cpp-devel capnproto-devel xorgproto lua54-devel gtest-devel"
depends="lua54"
