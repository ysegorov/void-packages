	vlicense LICENSE
}

librime-devel_package() {
	depends="librime>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove usr/share/cmake
	}
}
